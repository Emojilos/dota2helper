# Копия для локальной разработки: cp .env.example .env, затем впиши реальные значения.
# .env в .gitignore — никогда не коммить сюда реальные секреты.

# Токен STRATZ GraphQL API (https://stratz.com/api). Без него приложение работает
# без STRATZ-фич (см. src/main/data/StratzClient.ts createStratzClient()).
STRATZ_API_TOKEN=

# Токен для GSI-сервера (TASK-005/006) — должен совпадать с тем, что установщик
# cfg (TASK-006) пишет в gamestate_integration_midmind.cfg. Дев-фолбэк в коде:
# 'midmind-dev-token'.
MIDMIND_GSI_TOKEN=
